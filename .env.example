# ============================================================
# HCAI Compliance Engine — Environment Configuration
# Copy this file to .env and fill in your values.
# ============================================================

# ── Core (required) ─────────────────────────────────────────
# Anthropic API key — powers AHJ comment generation via Claude
ANTHROPIC_API_KEY=sk-ant-...

# ── API Auth ─────────────────────────────────────────────────
# Comma-separated API keys for /review, /rules, /audit endpoints.
# Leave empty to disable auth (development only).
# API_KEYS=key-abc123,key-def456

# ── Server ───────────────────────────────────────────────────
API_PORT=8000

# Base URL for generating links in emails and Stripe redirect URLs.
# Set to your public domain in production.
APP_BASE_URL=http://localhost:8000

# Allowed CORS origins (comma-separated, or * for all)
CORS_ORIGINS=*

# ── Stripe Billing ───────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
# Leave blank to run in dev mode (no payment required).
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Optional: pre-create a Price in Stripe dashboard and paste the ID here.
# If blank, a $49 ad-hoc price is created per checkout.
# STRIPE_PRICE_ID=price_...

# Price per report in cents (default: 4900 = $49.00)
REPORT_PRICE_CENTS=4900
REPORT_PRICE_NAME=HCAI Compliance Report

# ── Email Delivery ───────────────────────────────────────────
# PDF reports are emailed to customers when analysis completes.
# Leave SMTP_USER blank to disable email (dev mode).

# Gmail example:
#   1. Enable 2FA on your Google account
#   2. Create an App Password at https://myaccount.google.com/apppasswords
#   3. Use that 16-char password as SMTP_PASSWORD
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-app-password

# Display name for outgoing emails
EMAIL_FROM=HCAI Review <you@gmail.com>
EMAIL_REPLY_TO=hello@yourdomain.com

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Rate Limiting ────────────────────────────────────────────
# RATE_LIMIT_RPM=60
# RATE_LIMIT_BURST=10

# ── Claude Model ─────────────────────────────────────────────
# CLAUDE_MODEL=claude-sonnet-4-6

# ── Webhooks (optional) ──────────────────────────────────────
# WEBHOOK_URL=https://your-webhook-endpoint.com/hcai
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# NOTIFY_MIN_SEVERITY=Critical
