# ============================================================
# BlueprintIQ — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file to git.
# ============================================================

# ── Anthropic (REQUIRED) ─────────────────────────────────────
# Powers AI compliance analysis via Claude
# Get key: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk-ant-...

# Claude model (default is fine — don't change unless you know why)
# CLAUDE_MODEL=claude-sonnet-4-6

# ── JWT Auth (REQUIRED) ──────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Must be long, random, and SECRET. Never reuse across environments.
JWT_SECRET=change-me-generate-with-secrets-token-hex-32
JWT_EXPIRE_DAYS=30

# ── Stripe Billing (REQUIRED for subscriptions) ──────────────
# Live keys: https://dashboard.stripe.com/apikeys
# Test keys:  https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Create these in Stripe Dashboard → Products → Pricing
# Pro plan:    $299/mo recurring
STRIPE_PRO_PRICE_ID=price_...
# Agency plan: $899/mo recurring
STRIPE_AGENCY_PRICE_ID=price_...
# Pay-per-review (optional, for API access tier)
# STRIPE_PRICE_ID=price_...

# ── App URL (REQUIRED in production) ─────────────────────────
# Set to your Railway public domain, e.g. https://blueprintiq.up.railway.app
APP_BASE_URL=https://blueprintiq.up.railway.app

# ── Server ───────────────────────────────────────────────────
API_PORT=8000
CORS_ORIGINS=*

# ── Email Delivery (optional) ────────────────────────────────
# PDF reports are emailed to customers on completion.
# Leave SMTP_USER blank to disable email (dev/test mode).
#
# Gmail setup:
#   1. Enable 2FA on your Google account
#   2. Create App Password: https://myaccount.google.com/apppasswords
#   3. Use the 16-char app password below (not your Gmail password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-16-char-app-password
EMAIL_FROM=BlueprintIQ <hello@blueprintiq.io>
EMAIL_REPLY_TO=hello@blueprintiq.io

# ── Legacy API Key Auth (optional) ───────────────────────────
# Comma-separated static keys for machine-to-machine API access.
# Leave empty to rely on JWT auth only.
# API_KEYS=key-abc123,key-def456

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Pricing display ──────────────────────────────────────────
REPORT_PRICE_CENTS=4900
REPORT_PRICE_NAME=HCAI Compliance Report
