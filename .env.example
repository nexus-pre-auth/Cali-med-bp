# Anthropic API key (required for Claude-powered AHJ comment generation)
ANTHROPIC_API_KEY=sk-ant-...

# API authentication keys (comma-separated); leave empty to disable auth (dev mode)
# API_KEYS=key-abc123,key-def456

# API server port (docker-compose)
API_PORT=8000

# Allowed CORS origins (comma-separated, or * for all)
CORS_ORIGINS=*

# Claude model to use (defaults to claude-sonnet-4-6)
# CLAUDE_MODEL=claude-sonnet-4-6

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Webhook notifications (optional)
# WEBHOOK_URL=https://your-webhook-endpoint.com/hcai
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Minimum severity level to trigger webhook alerts (Critical, High, Medium, Low)
NOTIFY_MIN_SEVERITY=Critical
